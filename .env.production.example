# ============================================================================
# JT-Orga Production Environment Configuration
# Copy this file to .env and fill in the values
# ============================================================================

# ============================================================================
# Application Settings
# ============================================================================
NODE_ENV=production
PORT=3000

# ============================================================================
# Security (REQUIRED)
# ============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Generate with: openssl rand -base64 16
ADMIN_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_16

# ============================================================================
# Optional: Error Tracking (Sentry)
# ============================================================================
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# Optional: Firebase Push Notifications
# ============================================================================
# VITE_FIREBASE_API_KEY=your_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
# VITE_FIREBASE_APP_ID=1:123456789:web:abc123
# VITE_FIREBASE_VAPID_KEY=your_vapid_key

# ============================================================================
# Optional: AI Integration (Google Gemini)
# ============================================================================
# GEMINI_API_KEY=your_gemini_api_key

# ============================================================================
# Database Configuration
# ============================================================================
# SQLite database file path (inside container)
# This should match the volume mount in docker-compose.yml
DATABASE_PATH=/app/data/data.db

# ============================================================================
# Security Headers (configured in Caddy, not here)
# ============================================================================
# These are handled by the Caddyfile configuration
